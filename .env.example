OPENAI_API_KEY=sk-...
# Optional: override path to the CSV (defaults to Airline_Delay_Cause.csv next to app.py in src/airline_reliability/)
# AIRLINE_DELAY_CSV_PATH=/absolute/path/to/Airline_Delay_Cause.csv

# Optional RAG / embedding tuning (see README.md)
# AIRLINE_DELAY_EMBED_MODEL=text-embedding-3-small
# AIRLINE_DELAY_RAG_ROWS_PER_CHUNK=15

# Optional Gradio port
# GRADIO_SERVER_PORT=7860
